{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "启动 Vite 开发服务器",
      "type": "npm",
      "script": "dev",
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local:\\s+http://localhost:5173|ready in \\d+ ms)"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
